{
  "manifest_version": 3,
  "name": "Udemy Auto Translate",
  "version": "1.0.0",
  "description": "Udemyの練習問題切り替わり時にChromeの翻訳を自動再トリガー",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://*.udemy.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.udemy.com/*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
